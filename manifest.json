{
  "manifest_version": 3,
  "name": "Helper for Canvas SpeedGrader",
  "version": "0.1.0",
  "description": "Little funcationality improvements for Canvas SpeedGrader.",
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_icon": "icon.png",
    "default_popup": "extension/popup.html"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "background": {
    "service_worker": "extension/service-worker.js"
  },
  "host_permissions": [
    "https://*.instructure.com/*",
    "https://apps.powerapps.com/*",
    "https://runtime-app.powerapps.com/*",
    "https://runtime-app.powerplatform.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.instructure.com/courses/*/gradebook/speed_grader*"],
      "js": ["shared/message-types.js", "shared/settings.js", "shared/storage-utils.js", "content/loader-speedgrader.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://runtime-app.powerapps.com/*", "https://runtime-app.powerplatform.com/*"],
      "js": ["shared/message-types.js", "shared/storage-utils.js", "content/grading-queue.js"],
      "run_at": "document_end",
      "all_frames": true
    },
    {
      "matches": ["https://apps.powerapps.com/*"],
      "js": ["content/powerapps-domain-monitor.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://*.instructure.com/courses/*/groups*"],
      "js": ["shared/message-types.js", "content/groups-page.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://canvasdocs.instructure.com/*",
        "https://canvadocs.instructure.com/*",
        "https://*.instructure.com/api/v1/canvadoc_session*",
        "https://*.instructure.com/courses/*/assignments/*/submissions/*"
      ],
      "js": [
        "shared/message-types.js",
        "page/submission-adapters/iframe-content/document-renderer-adapter.js",
        "page/submission-adapters/iframe-content/discussion-posts-adapter.js",
        "content/iframe-content-loader.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "options_ui": {
    "page": "extension/options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": [
          "shared/message-types.js",
          "page/speedgrader.js",
          "page/submission-dispatcher.js",
          "page/submission-adapters/iframe-submission-adapter.js",
          "page/submission-adapters/iframe-content/document-renderer-adapter.js",
          "page/submission-adapters/iframe-content/discussion-posts-adapter.js"
        ],
      "matches": ["https://*.instructure.com/*"]
    }
  ]
}
